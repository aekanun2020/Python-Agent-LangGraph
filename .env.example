# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ:
#   cp .env.example .env
#
# หมายเหตุ: ไฟล์ .env ถูก gitignore ไว้แล้ว ห้าม commit คีย์จริงขึ้น repo

# OpenRouter API key — ขอได้ที่ https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoint ของ OpenRouter (ใช้รูปแบบ OpenAI-compatible)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# โมเดลที่ใช้ผ่าน OpenRouter (ทดสอบแล้วใช้งานได้)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# URL ของ MCP Server (Streamable HTTP) — ค่าเริ่มต้นคือ server จำลองในโปรเจกต์นี้
# เปลี่ยนเป็น MCP Server จริงของหลักสูตรที่ 1 ได้ เช่น MSSQL :9000 หรือ RAG :8000
MCP_SERVER_URL=http://127.0.0.1:9000/mcp

# (ตัวเลือก) URL ของ MCP MSSQL Server จริง สำหรับ agent_mssql_demo.py
# เช่น เปิด MCP MSSQL ในเครื่องแล้ว expose ผ่าน ngrok
MCP_MSSQL_URL=https://your-ngrok-subdomain.ngrok-free.app/mcp
